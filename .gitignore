# Ignore the entire data folder (and any subfolders like data/archive/)
data/raw/
data/processed/
data/archive/
data/interim/

# Also ignore loose heavy files just in case they end up outside the data folder
*.csv
*.zip
*.gz
*.parquet

# Ignore large model files
models/
*.pkl
*.joblib
*.h5
*.pt

# ---------------------------------------------------
# CODE ARCHIVES
# ---------------------------------------------------
code/archive/
code/*.html

# ---------------------------------------------------
# PYTHON & JUPYTER
# ---------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

